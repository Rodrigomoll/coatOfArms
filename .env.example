# ─── Azure OpenAI ───────────────────────────────────────────────────────────
# Your Azure OpenAI resource base URL (no trailing slash)
AZURE_OPENAI_ENDPOINT=https://vrm67-mm2giirz-swedencentral.cognitiveservices.azure.com

# Your Azure OpenAI API key (paste it here when you have it)
AZURE_OPENAI_KEY=your_azure_api_key_here

# The deployment name of your CHAT model in Azure OpenAI Studio
# Go to Azure OpenAI Studio → Deployments → find your GPT-4o or GPT-4 deployment name
AZURE_CHAT_DEPLOYMENT=gpt-4o

# The FULL URL for image generation (exactly as provided)
AZURE_IMAGE_ENDPOINT=https://vrm67-mm2giirz-swedencentral.cognitiveservices.azure.com/openai/deployments/gpt-image-1.5/images/generations?api-version=2024-02-01

# ─── Access Control ─────────────────────────────────────────────────────────
# This is the secret token people need in the URL to access the app
# Example URL: https://yourapp.com/?token=heraldry2025
# Change this to anything you want — make it hard to guess
ACCESS_TOKEN=heraldry2025

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
